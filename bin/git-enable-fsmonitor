#!/usr/bin/env bash
# git enable-fsmonitor — speed up `git status` in large repos via fsmonitor.
#
# Prefers git's built-in fsmonitor daemon (`core.fsmonitor=true`). On platforms
# where the daemon is unsupported (e.g. some Coder/devbox Linux images report
# "fsmonitor--daemon not supported on this platform"), falls back to the
# watchman query hook shipped alongside this script.
#
# Repo-local only — never touches global config.
#
# Usage (inside any git repo):
#   git enable-fsmonitor          # enable (daemon if supported, else watchman)
#   git enable-fsmonitor --off    # disable + stop watching
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOOK="$SCRIPT_DIR/git-fsmonitor-watchman"

info() { printf '\033[1;34m[fsmonitor]\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m[fsmonitor]\033[0m %s\n' "$*"; }
die()  { printf '\033[1;31m[fsmonitor]\033[0m %s\n' "$*" >&2; exit 1; }

# real git, not the `hub` shell alias
GIT=/usr/bin/git
command -v "$GIT" >/dev/null 2>&1 || GIT=git

"$GIT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git work tree"
TOPLEVEL="$("$GIT" rev-parse --show-toplevel)"

if [[ "${1:-}" == "--off" ]]; then
  "$GIT" config --unset core.fsmonitor || true
  command -v watchman >/dev/null 2>&1 && watchman watch-del "$TOPLEVEL" >/dev/null 2>&1 || true
  ok "disabled fsmonitor for $TOPLEVEL"
  exit 0
fi

# Is the built-in daemon supported on this platform?
daemon_status="$("$GIT" fsmonitor--daemon status 2>&1 || true)"
if [[ "$daemon_status" != *"not supported"* ]]; then
  "$GIT" config core.fsmonitor true
  info "using built-in fsmonitor daemon"
else
  command -v watchman >/dev/null 2>&1 || die "daemon unsupported and watchman not installed (brew install watchman)"
  [[ -x "$HOOK" ]] || die "shared watchman hook missing/not executable: $HOOK"
  "$GIT" config core.fsmonitor "$HOOK"
  info "built-in daemon unsupported here; using watchman hook"
fi

"$GIT" config core.untrackedCache true

info "warming fsmonitor (first status crawls the whole tree; subsequent runs are fast)..."
"$GIT" status --porcelain >/dev/null
ok "enabled for $TOPLEVEL"
ok "core.fsmonitor -> $("$GIT" config --get core.fsmonitor)"
