#!/usr/bin/env bash
# git optimize-figma — apply the "transparent" figma/figma performance settings.
#
# Source: Figma "Git & GitHub" notion doc, Performance > Transparent changes.
# These are safe/idempotent and REPO-LOCAL (never global) — the doc warns that
# global config breaks external-repo fetches like fs wasm.
#
# Applies:
#   - fsmonitor (via git enable-fsmonitor: daemon if supported, else watchman)
#   - feature.manyFiles=true  (index.skipHash, index.version=4, core.untrackedCache)
#   - core.commitgraph=true
#   - fetch.writeCommitGraph=true
#   - git commit-graph write --reachable   (prime the cache)
#
# Usage (inside the figma/figma repo):
#   git optimize-figma          # apply
#   git optimize-figma --force  # apply even if origin doesn't look like figma/figma
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

ok()   { printf '\033[1;32m[optimize-figma]\033[0m %s\n' "$*"; }
info() { printf '\033[1;34m[optimize-figma]\033[0m %s\n' "$*"; }
die()  { printf '\033[1;31m[optimize-figma]\033[0m %s\n' "$*" >&2; exit 1; }

GIT=/usr/bin/git
command -v "$GIT" >/dev/null 2>&1 || GIT=git

"$GIT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git work tree"

# Guard: this is figma/figma-specific. Refuse elsewhere unless --force.
origin_url="$("$GIT" config --get remote.origin.url || true)"
if [[ "${1:-}" != "--force" && "$origin_url" != *figma/figma* ]]; then
  die "origin ($origin_url) doesn't look like figma/figma; re-run with --force to apply anyway"
fi

# fsmonitor (repo-local). Delegates daemon-vs-watchman decision to the helper.
"$SCRIPT_DIR/git-enable-fsmonitor"

# manyFiles bundle: index.skipHash + index.version=4 + core.untrackedCache
"$GIT" config feature.manyFiles true
# commit-graph cache speeds up traversal (status/log/rebase)
"$GIT" config core.commitgraph true
"$GIT" config fetch.writeCommitGraph true

info "priming commit-graph (git commit-graph write --reachable)..."
"$GIT" commit-graph write --reachable

ok "transparent perf settings applied to $("$GIT" rev-parse --show-toplevel)"
ok "run 'git restrict-refs-figma' separately if you also want the ref-restriction speedup"
